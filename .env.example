# TikTok AI Creator Suite — Environment Variables

# API Server
API_HOST=0.0.0.0
API_PORT=8800
DEBUG=true

# OpenAI (script generation, chat, listings)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ElevenLabs (TTS voice generation)
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Replicate (AI image generation)
REPLICATE_API_TOKEN=

# Suno (AI music generation)
SUNO_API_KEY=

# Pexels (stock footage/images - free)
PEXELS_API_KEY=

# TikTok Shop API (optional)
TIKTOK_SHOP_API_KEY=
TIKTOK_SHOP_SECRET=

# Processing settings
MAX_VIDEO_DURATION=600
MAX_FILE_SIZE_MB=500
VIDEO_FPS=30
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# Cost control
DAILY_BUDGET_USD=10.0
